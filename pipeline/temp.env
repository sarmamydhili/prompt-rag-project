# Task and Skill settings
TASK_NAME=AP Physics Task
SKILL_IDS=200,201,202

# Question generation settings
NUM_QUESTIONS=5
PROMPT_TYPE=default
OUTPUT_MODE=mongo
CHUNK_SIZE=1000
TEMPERATURE=0.7

# File paths
PDF_PATH=data/sample.pdf
PROMPT_TEMPLATE_PATH=prompts/default_prompt.txt

# Sample question settings
USE_SAMPLE_QUESTIONS=true
NUM_SAMPLE_QUESTIONS=3
SAMPLE_QUESTION_WEIGHT=0.3

# PDF processing settings
PDF_EXTRACTION_TIMEOUT=30
MAX_PDF_PAGES=10

# Logging settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database configurations
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=adaptive_db
MONGO_URI=mongodb://localhost:27017/
MONGO_ADAPTIVE_DB_NAME=adaptive_db
MONGO_QUESTIONS_COLLECTION=questions
CHROMA_COLLECTION_NAME=questions

# API configurations
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
DEEPSEEK_API_KEY=your_deepseek_key
GEMINI_API_KEY=your_gemini_key
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-3-opus-20240229 